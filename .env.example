# Environment contract for Ticket Booth (Vite)
# Copy to `.env` for local overrides. Never commit real secrets.

# Required for production / preview builds (no silent testapi fallback).
# Leave empty in local DEV to use the Vite `/clubman` proxy.
VITE_API_BASE_URL=

# Required — ticket resend email API host (no hardcoded default in app).
VITE_RESEND_TICKET_API_BASE_URL=

# Dev-only tunnel helpers (temporary).
# VITE_TUNNEL_URL=
# VITE_USE_VENUE_TUNNEL=
